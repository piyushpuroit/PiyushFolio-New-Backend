            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"johndoe@example.com\",\n  \"subject\": \"Inquiry\",\n  \"phone\": \"+1234567890\",\n  \"message\": \"Hello, I would like to collaborate on a project!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/contact",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "contact"
              ]
            }
          }
        },
        {
          "name": "Get Contacts (Paginated & Filtered)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/contact?page=0&size=10&sortBy=createdAt&sortDir=desc",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "contact"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                },
                {
                  "key": "sortBy",
                  "value": "createdAt"
                },
                {
                  "key": "sortDir",
                  "value": "desc"
                },
                {
                  "key": "email",
                  "value": "johndoe",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "Mark Read status",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"read\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/contact/1/read",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "contact",
                "1",
                "read"
              ]
            }
          }
        },
        {
